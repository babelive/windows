# Auto-detect text files and normalize line endings to LF in the repo,
# checked out as the platform default (CRLF on Windows). Stops "the
# whole file changed" diffs after someone runs the project on macOS or
# in WSL.
* text=auto

# ===== Force LF (cross-platform tools) =====
*.sh           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf

# ===== Force CRLF (Windows-native) =====
# WPF / MSBuild tooling regenerates these with CRLF; pinning matches.
*.cs           text eol=crlf
*.xaml         text eol=crlf
*.csproj       text eol=crlf
*.sln          text eol=crlf
*.props        text eol=crlf
*.targets      text eol=crlf
*.config       text eol=crlf

# ===== Binaries — never diff, never line-end normalize =====
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.dll    binary
*.exe    binary
*.pdb    binary
*.snk    binary
*.pfx    binary

# Mark generated files in GitHub diffs as collapsed by default
*.g.cs   linguist-generated=true
