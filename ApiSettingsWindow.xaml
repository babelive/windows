<Window x:Class="Babelive.ApiSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="API Settings"
        Width="580" Height="420"
        MinWidth="480" MinHeight="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="Microsoft YaHei UI, Segoe UI, PingFang SC"
        FontSize="13"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="36"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{StaticResource WindowBg}"
            BorderBrush="{StaticResource WindowBorder}"
            BorderThickness="1"
            CornerRadius="12"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="API Settings"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"
                           Foreground="{StaticResource TextSecondary}"/>
                <Button Grid.Column="1"
                        Style="{StaticResource CloseCaptionButton}"
                        Content="✕"
                        Click="CancelBtn_Click"
                        ToolTip="Cancel"/>
            </Grid>

            <!-- Form content -->
            <Grid Grid.Row="1" Margin="28,12,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="API ENDPOINT"
                           Style="{StaticResource SectionHeader}"/>
                <TextBox  Grid.Row="1" x:Name="BaseUrlBox"
                          Style="{StaticResource ModernInput}"
                          Margin="0,2,0,0"
                          FontFamily="Consolas, Microsoft YaHei UI"/>
                <TextBlock Grid.Row="2"
                           Style="{StaticResource HelperText}"
                           Text="Default is OpenAI's official endpoint. Accepts ws://, wss://, http://, https:// — http/s is auto-converted. For reverse-proxy setups, include any path prefix, e.g. https://my-proxy.example.com/openai."/>

                <TextBlock Grid.Row="4" Text="API KEY"
                           Style="{StaticResource SectionHeader}"/>
                <TextBox  Grid.Row="5" x:Name="ApiKeyBox"
                          Style="{StaticResource ModernInput}"
                          Margin="0,2,0,0"
                          FontFamily="Consolas, Microsoft YaHei UI"/>
                <TextBlock Grid.Row="6"
                           Style="{StaticResource HelperText}"
                           Text="Required to start translation. Stored locally in %APPDATA%\Babelive\settings.json (plain JSON, no encryption — same trust model as the rest of your local profile)."/>

                <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource FlatButton}"
                            Content="Cancel" Width="100" Height="34"
                            Margin="0,0,8,0"
                            Click="CancelBtn_Click"
                            IsCancel="True"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Save" Width="100" Height="34"
                            Click="SaveBtn_Click"
                            IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
