<Window x:Class="Babelive.LyricWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Babelive Lyrics"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="1100" Height="120"
        MinWidth="400" MinHeight="80"
        MaxWidth="3000" MaxHeight="400"
        WindowStartupLocation="Manual"
        FontFamily="Microsoft YaHei UI, Microsoft YaHei, PingFang SC, Segoe UI"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">

    <Window.Resources>
        <!-- Warm "TTPlayer/Kugou" gradient: white top → cream → amber. Highest legibility on any wallpaper. -->
        <LinearGradientBrush x:Key="TranslationGradient" StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Offset="0.0"  Color="#FFFFFFFF"/>
            <GradientStop Offset="0.55" Color="#FFFFE9A8"/>
            <GradientStop Offset="1.0"  Color="#FFFFB938"/>
        </LinearGradientBrush>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FFE0E0E0"/>
            <!-- Segoe UI first so plain Latin labels (Start, A−, A+) render
                 correctly. Symbol fallback covers ⚙, ▶, ■, ✕ etc. MDL2
                 was a wrong default — its private-use range overrides Latin
                 glyphs with tofu. -->
            <Setter Property="FontFamily" Value="Segoe UI, Segoe UI Symbol, Microsoft YaHei UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#66FFFFFF"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#88FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer transparent grid still receives clicks/drag (1/255 alpha fill). -->
    <Grid x:Name="RootGrid" Background="#01000000">

        <!-- Always-on translucent backdrop so lyrics stay legible on busy /
             bright wallpapers. Pure transparency was unreadable against e.g.
             starry-sky desktops. Hover intensifies via the second border. -->
        <Border x:Name="AmbientFrame"
                Background="#882A2A2A"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="12"
                Margin="6"
                IsHitTestVisible="False"/>
        <!-- Hover boost: darker + brighter border, fades in on mouse-over. -->
        <Border x:Name="HoverFrame"
                Background="#66000000"
                BorderBrush="#55FFFFFF"
                BorderThickness="1"
                CornerRadius="12"
                Margin="6"
                Opacity="0"
                IsHitTestVisible="False"/>

        <!-- Lyric stack centered in the window. The toolbar is a SIBLING
             overlay (next element below) instead of a Grid row, so the
             window can collapse down to "just-fits-the-text" height
             without burning ~36 px on a dedicated toolbar row.
             Order matters: StackPanel comes first → renders BELOW the
             toolbar; toolbar renders on top so its hover-faded buttons
             always sit over (and never get clipped by) the lyrics. -->
        <StackPanel VerticalAlignment="Center" Margin="16,4,16,4">

                <!-- Source line — ice-blue, brighter than before for legibility,
                     bigger glow halo so it reads on busy backgrounds. -->
                <Viewbox StretchDirection="DownOnly" Stretch="Uniform" Margin="0,0,0,8" MaxHeight="28">
                    <TextBlock x:Name="SourceText"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#FFEFF8FF"
                               Opacity="0.95"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Center"
                               Text="">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="0" Opacity="1"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Viewbox>

                <!-- Translation line — gradient fill + 4-direction stacked stroke + soft glow.
                     The 4 stroke TextBlocks Bind to the main TranslationText so they always
                     stay in sync; together they fake a 1.5 px black outline (WPF has no
                     native text stroke). The main TextBlock on top has the gradient and a
                     12 px black glow underneath. -->
                <Viewbox StretchDirection="DownOnly" Stretch="Uniform" MaxHeight="56">
                    <Grid>
                        <!-- Strong outer halo: a wide, soft black glow that reads on any wallpaper. -->
                        <TextBlock FontSize="{Binding ElementName=TranslationText, Path=FontSize}"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   Text="{Binding ElementName=TranslationText, Path=Text}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="NoWrap">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="0" Opacity="1"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <!-- 4-direction stacked stroke (±1.5 px) for a true outline. -->
                        <TextBlock FontSize="{Binding ElementName=TranslationText, Path=FontSize}"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   Text="{Binding ElementName=TranslationText, Path=Text}"
                                   Margin="-1.5,0,1.5,0"
                                   HorizontalAlignment="Center"
                                   TextWrapping="NoWrap"/>
                        <TextBlock FontSize="{Binding ElementName=TranslationText, Path=FontSize}"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   Text="{Binding ElementName=TranslationText, Path=Text}"
                                   Margin="1.5,0,-1.5,0"
                                   HorizontalAlignment="Center"
                                   TextWrapping="NoWrap"/>
                        <TextBlock FontSize="{Binding ElementName=TranslationText, Path=FontSize}"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   Text="{Binding ElementName=TranslationText, Path=Text}"
                                   Margin="0,-1.5,0,1.5"
                                   HorizontalAlignment="Center"
                                   TextWrapping="NoWrap"/>
                        <TextBlock FontSize="{Binding ElementName=TranslationText, Path=FontSize}"
                                   FontWeight="Bold"
                                   Foreground="#FF000000"
                                   Text="{Binding ElementName=TranslationText, Path=Text}"
                                   Margin="0,1.5,0,-1.5"
                                   HorizontalAlignment="Center"
                                   TextWrapping="NoWrap"/>

                        <!-- Foreground gradient with a tighter inner glow on top of the outer halo. -->
                        <TextBlock x:Name="TranslationText"
                                   FontSize="34" FontWeight="Bold"
                                   Foreground="{StaticResource TranslationGradient}"
                                   TextWrapping="NoWrap"
                                   HorizontalAlignment="Center"
                                   Text="Babelive — hover for controls, click ⚙ to configure">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0" Opacity="0.95"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </Viewbox>
            </StackPanel>

        <!-- Top-right toolbar (fades in on hover, overlays the lyric area) -->
        <Border x:Name="Toolbar"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,12,0"
                Opacity="0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="ToggleBtn" Style="{StaticResource ToolbarButton}"
                        Width="64" Content="▶ Start" FontSize="11"
                        Click="ToggleBtn_Click"
                        ToolTip="Start / stop translation"/>
                <Button x:Name="FontMinusBtn" Style="{StaticResource ToolbarButton}"
                        Content="A−" FontSize="12"
                        Click="FontMinusBtn_Click"
                        ToolTip="Decrease translation font size"/>
                <Button x:Name="FontPlusBtn" Style="{StaticResource ToolbarButton}"
                        Content="A+" FontSize="12"
                        Click="FontPlusBtn_Click"
                        ToolTip="Increase translation font size"/>
                <Button x:Name="VolDownBtn" Style="{StaticResource ToolbarButton}"
                        Content="&#x1F509;" FontSize="14"
                        FontFamily="Segoe UI Emoji, Segoe UI Symbol"
                        Click="VolDownBtn_Click"
                        ToolTip="Decrease translation playback volume"/>
                <Button x:Name="VolUpBtn" Style="{StaticResource ToolbarButton}"
                        Content="&#x1F50A;" FontSize="14"
                        FontFamily="Segoe UI Emoji, Segoe UI Symbol"
                        Click="VolUpBtn_Click"
                        ToolTip="Increase translation playback volume"/>
                <Button x:Name="SettingsBtn" Style="{StaticResource ToolbarButton}"
                        Content="&#x2699;" FontSize="14"
                        Click="SettingsBtn_Click"
                        ToolTip="Settings…"/>
                <Button x:Name="HideBtn" Style="{StaticResource ToolbarButton}"
                        Content="&#x2715;" FontSize="11"
                        Click="HideBtn_Click"
                        ToolTip="Hide overlay (re-open from tray)"/>
            </StackPanel>
        </Border>

        <!-- Bottom-right resize grip — drag to resize. Faintly visible at
             rest so it's discoverable; brightens on hover. The actual resize
             is handed off to the OS via WM_NCLBUTTONDOWN+HTBOTTOMRIGHT
             because WindowStyle=None + AllowsTransparency suppresses the
             standard resize border.

             IMPORTANT: the click target must be a Border with a
             (near-)transparent Background — a bare Path with only a Stroke
             (no Fill) is hit-tested ONLY along the actual rendered stroke
             pixels, so 1.5 px-wide diagonal lines are nearly impossible to
             click. The 24×24 Border gives a fat hit area; the Path inside
             is purely decorative (IsHitTestVisible=False so clicks bypass
             it and reach the Border). -->
        <Border x:Name="ResizeGrip"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,8,8"
                Width="24" Height="24"
                Background="#01000000"
                Cursor="SizeNWSE"
                Opacity="0.4"
                MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                MouseMove="ResizeGrip_MouseMove"
                MouseLeftButtonUp="ResizeGrip_MouseLeftButtonUp">
            <Path Stroke="#FFFFFFFF"
                  StrokeThickness="1.5"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Width="12" Height="12"
                  HorizontalAlignment="Right" VerticalAlignment="Bottom"
                  IsHitTestVisible="False"
                  Data="M 1,11 L 11,1  M 5,11 L 11,5  M 9,11 L 11,9"/>
        </Border>
    </Grid>
</Window>
